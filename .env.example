# TeachFlow AI environment template
# Copy to .env locally. Khong commit .env that.

# Frontend
URL_BACKEND=http://localhost:3000/api/v1

# Backend
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase
URL_SUPABASE=https://your-project.supabase.co
PUBLIC_API_KEY_SUPABASE=replace-with-supabase-anon-key
SECRET_API_KEY_SUPABASE=replace-with-supabase-service-role-key

# AI provider
OPENAI_API_KEY=replace-with-provider-api-key
OPENAI_MODEL=gpt-4o-mini

# Optional NVIDIA provider
NVIDIA_OPENAI_API_KEY=
NVIDIA_OPENAI_MODEL=openai/gpt-oss-120b
NVIDIA_OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# AI Hook Logging, neu moi truong lop hoc yeu cau
AI_LOG_SERVER=
AI_LOG_API_KEY=
AI_LOG_DIR=.ai-log
