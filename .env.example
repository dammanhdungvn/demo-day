# TeachFlow AI environment template
# Copy to .env locally. Khong commit .env that.

# Frontend
# Local dev uses Vite proxy, so browser requests stay on the frontend origin.
# For deploy/static preview, set this to the public backend URL ending in /api/v1.
URL_BACKEND=/api/v1

# Backend
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production default uses Supabase Auth + Postgres persistence.
LEARNING_REPOSITORY=postgres
AUTH_PROVIDER=supabase
AUTH_REPOSITORY=postgres
# Local demo shortcuts are opt-in only. Keep false for real accounts.
ENABLE_DEMO_LOGIN=false
# Production owner bootstrap. These are allowlists, not passwords.
# A Supabase-authenticated user matching one of these values is provisioned as role system_admin.
SYSTEM_ADMIN_EMAILS=
SYSTEM_ADMIN_USER_IDS=
SYSTEM_ADMIN_ORGANIZATION_ID=org-platform
SYSTEM_ADMIN_ORGANIZATION_NAME=TeachFlow Platform
# Optional real-account bootstrap/QA. Put real passwords in .env.local or shell only.
TEACHFLOW_BOOTSTRAP_OWNER_EMAIL=
TEACHFLOW_BOOTSTRAP_OWNER_PASSWORD=
TEACHFLOW_BOOTSTRAP_ADMIN_EMAIL=
TEACHFLOW_BOOTSTRAP_ADMIN_PASSWORD=
TEACHFLOW_BOOTSTRAP_TEACHER_EMAIL=
TEACHFLOW_BOOTSTRAP_TEACHER_PASSWORD=
TEACHFLOW_BOOTSTRAP_STUDENT_EMAIL=
TEACHFLOW_BOOTSTRAP_STUDENT_PASSWORD=
TEACHFLOW_QA_ADMIN_EMAIL=
TEACHFLOW_QA_ADMIN_PASSWORD=

# Optional recruiter-facing real account shortcuts. These values are bundled
# into the frontend when set, so only use dedicated QA/recruiter accounts.
TEACHFLOW_PUBLIC_ADMIN_EMAIL=
TEACHFLOW_PUBLIC_ADMIN_PASSWORD=
TEACHFLOW_PUBLIC_TEACHER_EMAIL=
TEACHFLOW_PUBLIC_TEACHER_PASSWORD=
TEACHFLOW_PUBLIC_STUDENT_EMAIL=
TEACHFLOW_PUBLIC_STUDENT_PASSWORD=
TEACHFLOW_PUBLIC_REAL_ACCOUNT_PASSWORD=

# Knowledge storage governance
# metadata keeps local/dev raw uploads out of git/deploy while still recording governance metadata.
# supabase stores raw PDF bytes in Supabase Storage using SECRET_API_KEY_SUPABASE server-side only.
DOCUMENT_STORAGE_PROVIDER=metadata
DOCUMENT_STORAGE_BUCKET=teachflow-knowledge-raw
DOCUMENT_CONTEXTUAL_TTL_DAYS=90
DOCUMENT_CONTEXTUAL_QUOTA_BYTES=104857600
DOCUMENT_LIBRARY_QUOTA_BYTES=1073741824

# Supabase
URL_SUPABASE=https://your-project.supabase.co
PUBLIC_API_KEY_SUPABASE=replace-with-supabase-anon-key
SECRET_API_KEY_SUPABASE=replace-with-supabase-service-role-key
SUPABASE_DB_NAME=postgres
SUPABASE_DB_PASSWORD=replace-with-database-password
# Prefer pooler in environments without IPv6. Do not commit real connection strings.
SUPABASE_POOLER_CONNECTING_STRING=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DIRECT_CONNECTING_STRING=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# AI provider
OPENAI_API_KEY=replace-with-provider-api-key
OPENAI_MODEL=gpt-4o-mini
# RAG embeddings. Keep dimensions 384 unless database vector dimension is migrated.
EMBEDDING_PROVIDER=local-hash
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=384
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
# Guard expensive AI generation actions per user.
AI_ACTION_RATE_LIMIT_ENABLED=true
AI_ACTION_RATE_LIMIT_MAX_REQUESTS=12
AI_ACTION_RATE_LIMIT_WINDOW_SECONDS=3600

# Optional NVIDIA provider
NVIDIA_OPENAI_API_KEY=
NVIDIA_OPENAI_MODEL=openai/gpt-oss-120b
NVIDIA_OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# AI Hook Logging, neu moi truong lop hoc yeu cau
AI_LOG_SERVER=
AI_LOG_API_KEY=
AI_LOG_DIR=.ai-log
