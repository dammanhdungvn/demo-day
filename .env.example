# TeachFlow AI environment template
# Copy to .env locally. Khong commit .env that.

# Frontend
VITE_BACKEND_URL=http://localhost:3000/api/v1
BACKEND_URL=http://localhost:3000/api/v1

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3000
API_BASE_PATH=/api/v1
LOG_LEVEL=INFO

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# AI provider
AI_PROVIDER=openai
AI_API_KEY=replace-with-provider-api-key
GENERATION_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Optional OpenAI-compatible provider override
AI_BASE_URL=

# Optional NVIDIA provider
NVIDIA_OPENAI_API_KEY=
NVIDIA_OPENAI_MODEL=openai/gpt-oss-120b
NVIDIA_OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# AI Hook Logging, neu moi truong lop hoc yeu cau
AI_LOG_SERVER=
AI_LOG_API_KEY=
AI_LOG_DIR=.ai-log
